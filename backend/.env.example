# Server
PORT=3000
CORS_ORIGIN=https://your-domain.com
RATE_LIMIT_MAX=300

# Auth
ADMIN_PASSWORD=your-admin-password
JWT_SECRET=your-long-random-secret
JWT_EXPIRES_IN=12h

# LLM (user can override in Settings)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Agent workspace
NUDGEBOT_WORKDIR=./workspace

# Google Jules
JULES_API_KEY=

# Email notifications (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@your-domain.com

# GitHub memory (cross-session context persistence)
GITHUB_CONTEXT_TOKEN=
GITHUB_CONTEXT_REPO=                    # e.g. mylogin/nudgebot-context (auto-created if blank)

# MCP: GitHub
GITHUB_PERSONAL_ACCESS_TOKEN=

# MCP: Jira
JIRA_API_TOKEN=
JIRA_EMAIL=
JIRA_URL=

# MCP: Confluence
CONFLUENCE_API_TOKEN=
CONFLUENCE_EMAIL=
CONFLUENCE_URL=

# MCP: Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SERVICE_ACCOUNT_JSON=

# MCP: Render
RENDER_API_KEY=

# MCP: Netlify
NETLIFY_AUTH_TOKEN=
