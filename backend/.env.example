# LLM provider
LLM_PROVIDER=deepseek
LLM_MODEL=
LLM_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# NudgeBot workspace
NUDGEBOT_WORKDIR=./workspace

# Google Jules
JULES_API_KEY=

# GitHub / MCP
GITHUB_PERSONAL_ACCESS_TOKEN=

# GitHub Context persistence (mémoire cross-sessions)
GITHUB_CONTEXT_TOKEN=
GITHUB_CONTEXT_REPO=owner/nudgebot-context

# Jira
JIRA_API_TOKEN=
JIRA_EMAIL=
JIRA_URL=

# Confluence
CONFLUENCE_API_TOKEN=
CONFLUENCE_EMAIL=
CONFLUENCE_URL=

# Google Calendar / Workspace MCP
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Optional JSON stringified service account credentials
GOOGLE_SERVICE_ACCOUNT_JSON=

# Render MCP
RENDER_API_KEY=

# Netlify MCP
NETLIFY_AUTH_TOKEN=
