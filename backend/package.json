{
  "name": "nudgebot-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm --prefix ../frontend run build && tsc -p tsconfig.json && rm -rf public && mkdir -p public && cp -r ../frontend/dist/* public/",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.2.8",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.3",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "blazerjob": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "openai": "^4.79.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
