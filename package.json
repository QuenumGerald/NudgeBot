{
  "name": "nudgebot-monorepo",
  "version": "1.0.0",
  "description": "NudgeBot - Personal AI Assistant",
  "author": "Quenum Gerald <geraldquenum9@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuenumGerald/NudgeBot.git"
  },
  "main": "desktop.js",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "install:all": "node scripts/setup.mjs",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && npm install --legacy-peer-deps && npx tsc",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "cd backend && node dist/server.js",
    "dev": "cd backend && npx tsx src/server.ts",
    "desktop:start": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder",
    "uninstall": "node scripts/uninstall.mjs"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.62",
    "@google/jules-sdk": "^0.2.0",
    "@mastra/core": "1.32.1",
    "@mastra/mcp": "1.7.0",
    "blazerjob": "^2.0.4",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "tsx": "^4.21.0",
    "zod": "^3.24.2"
  },
  "build": {
    "appId": "com.nudgebot.app",
    "productName": "NudgeBot",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "desktop.js",
      "preload.js",
      "backend/dist/**/*",
      "backend/.env.example",
      "frontend/dist/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
