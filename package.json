{
  "name": "nudgebot-monorepo",
  "version": "1.0.0",
  "main": "desktop.js",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "install:all": "node scripts/setup.mjs",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && npm install --legacy-peer-deps && npx tsc",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "cd backend && node dist/server.js",
    "dev": "cd backend && npx tsx src/server.ts",
    "desktop:start": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.nudgebot.app",
    "productName": "NudgeBot",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "desktop.js",
      "preload.js",
      "backend/dist/**/*",
      "backend/node_modules/**/*",
      "backend/.env.example",
      "frontend/dist/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
